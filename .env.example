# ChaosProbe environment variables
#
# Copy this file to .env and adjust. The CLI auto-loads .env at startup via
# python-dotenv (see chaosprobe/cli.py); shell-exported variables and
# command-line flags both win over .env values.
# find_dotenv walks upward from CWD, so this file works whether you run
# from the repo root or from chaosprobe/.

# --- Neo4j (graph store) ---------------------------------------------------
# Read by: chaosprobe run, chaosprobe graph *, chaosprobe ml-export
# Defined in: chaosprobe/chaosprobe/commands/shared.py,
#             chaosprobe/chaosprobe/commands/run_cmd.py,
#             chaosprobe/chaosprobe/commands/visualize_cmd.py
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=chaosprobe

# --- Kubernetes ------------------------------------------------------------
# Standard kubectl variable. ChaosProbe doesn't read it directly, but the
# Kubernetes Python client respects it. Uncomment to point at a non-default
# kubeconfig.
# KUBECONFIG=~/.kube/config-chaosprobe

# --- Kubespray / Ansible ---------------------------------------------------
# Sudo password for `ansible become` during cluster create/destroy.
# Read by: chaosprobe cluster create, chaosprobe cluster destroy
# Defined in: chaosprobe/chaosprobe/commands/cluster_cmd.py
ANSIBLE_BECOME_PASS=

# --- Container registry for Rust cmdProbes ---------------------------------
# Registry HOST (no namespace). The namespace comes from
# CHAOSPROBE_REGISTRY_USER below, so the final image path is
# ``{REGISTRY}/{USER}/{scenario}-{probe}:{hash}``.
# Read by: chaosprobe run (auto-build), chaosprobe probe build
# Defined in: chaosprobe/chaosprobe/probes/builder.py (DEFAULT_REGISTRY),
#             chaosprobe/chaosprobe/commands/probe_cmd.py,
#             chaosprobe/chaosprobe/commands/run_cmd.py
CHAOSPROBE_REGISTRY=ghcr.io

# Required when pushing probe images. The builder runs
# `docker login <registry-host> --password-stdin` once before the first push;
# missing values raise ProbeBuilderError instead of falling through to any
# pre-existing ~/.docker/config.json credentials.
# For ghcr.io the PASSWORD is a GitHub Personal Access Token with the
# write:packages scope (https://github.com/settings/tokens).
CHAOSPROBE_REGISTRY_USER=yhu02
CHAOSPROBE_REGISTRY_PASSWORD=
